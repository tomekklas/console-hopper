{
  "manifest_version": 3,
  "name": "Console Hopper",
  "version": "1.0.2",
  "description": "For AWS: hop between consoles fast — SAML role-picker filters, deep-link services, env-coloured tabs, tab groups.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "tabGroups"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://signin.aws.amazon.com/saml",
        "https://*.signin.aws.amazon.com/saml"
      ],
      "js": [
        "lib/jquery.min.js",
        "content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://console.aws.amazon.com/*",
        "https://*.console.aws.amazon.com/*"
      ],
      "js": [
        "console-decorator.js"
      ],
      "run_at": "document_start"
    }
  ]
}
